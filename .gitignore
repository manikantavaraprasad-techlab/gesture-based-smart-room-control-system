# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log

# ── Project-specific ──────────────────────────────────────────────────────
# Large model files (downloaded automatically; don’t commit)
models/*.caffemodel
models/*.prototxt

