*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Unit test / coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.nox/

# Type checkers / linters
.mypy_cache/
